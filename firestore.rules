rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra padrão de negação: bloqueia qualquer acesso que não seja explicitamente liberado abaixo
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper para verificar se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null && request.auth.token != null;
    }

    // Helper para verificar se o token do usuário contém e-mail válido
    function hasEmail() {
      return isAuthenticated() && 'email' in request.auth.token && request.auth.token.email != null;
    }

    // Helper para verificar se o usuário possui cargo de administrador no Firestore
    function isAdmin() {
      return hasEmail() && 
        exists(/databases/$(database)/documents/usuarios/$(request.auth.token.email.lower())) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.token.email.lower())).data.role == 'admin';
    }

    // Coleção: usuarios (Perfis e cargos dos usuários do app)
    match /usuarios/{email} {
      allow read: if isAuthenticated() && (
        (hasEmail() && request.auth.token.email.lower() == email) || 
        isAdmin()
      );
      
      // Criação: Apenas se for o próprio usuário criando sua conta com papel padrão 'driver' (evita auto-promoção)
      allow create: if isAdmin() || (
        isAuthenticated() && 
        hasEmail() && 
        request.auth.token.email.lower() == email && 
        request.resource.data.role == 'driver' &&
        request.resource.data.email == email
      );
      
      // Atualização: Usuários comuns podem atualizar seus próprios dados (como pushToken), mas NUNCA alterar seu papel (role)
      allow update: if isAdmin() || (
        isAuthenticated() && 
        hasEmail() && 
        request.auth.token.email.lower() == email && 
        request.resource.data.role == resource.data.role
      );
      
      allow delete: if isAdmin();
    }

    // Coleção: viagens (Escalas de viagens dos motoristas)
    match /viagens/{tripId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      
      // Atualização: Admins podem atualizar tudo.
      // Motoristas só podem iniciar/concluir se forem o motorista designado e não estiverem reatribuindo a viagem a outro motorista
      allow update: if isAdmin() || (
        isAuthenticated() && 
        hasEmail() &&
        (resource.data.motoristaId == request.auth.token.email.lower() || resource.data.motoristaEmail == request.auth.token.email.lower()) &&
        (request.resource.data.motoristaId == resource.data.motoristaId || request.resource.data.motoristaEmail == resource.data.motoristaEmail)
      );
    }

    // Coleção: trips (Histórico de viagens encerradas para painel administrativo)
    match /trips/{tripId} {
      allow read: if isAuthenticated();
      
      // Criação: Qualquer motorista autenticado pode salvar o fechamento correspondente ao seu próprio ID
      allow create: if isAuthenticated() && (
        (hasEmail() && request.resource.data.driverId == request.auth.token.email.lower()) || 
        isAdmin()
      );
        
      allow update, delete: if isAdmin();
    }

    // Coleção: veiculos (Dados da frota da empresa)
    match /veiculos/{vehicleId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      
      // Atualização: Admins podem editar tudo. Motoristas só podem atualizar a quilometragem (kmAtual) se ela aumentar
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kmAtual']) &&
        request.resource.data.kmAtual >= resource.data.kmAtual
      );
    }

    // Coleção: funcionarios (Dados e residências dos passageiros da JBS)
    match /funcionarios/{empId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coleção: locais_favoritos (CDA, JBS e locais rápidos)
    match /locais_favoritos/{locId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coleção: avarias (Relatórios de avarias dos carros enviados por motoristas)
    match /avarias/{reportId} {
      allow read: if isAuthenticated();
      
      // Criação: Qualquer motorista autenticado pode criar, contanto que o e-mail no relatório coincida com seu login
      allow create: if isAuthenticated() && 
        hasEmail() &&
        request.resource.data.motoristaEmail == request.auth.token.email.lower();
        
      // Atualização/Exclusão: Apenas administradores podem atualizar o status da avaria ou apagá-la
      allow update, delete: if isAdmin();
    }

    // Coleção: reembolsos (Pedidos de reembolso enviados à central e IA)
    match /reembolsos/{reimbId} {
      allow read: if isAuthenticated() && (
        (hasEmail() && resource.data.motoristaId == request.auth.token.email.lower()) || 
        isAdmin()
      );
      
      // Criação: O motorista só pode criar reembolsos para si mesmo, com valor positivo e com status inicial 'pendente'
      allow create: if isAuthenticated() && 
        hasEmail() &&
        request.resource.data.motoristaId == request.auth.token.email.lower() &&
        request.resource.data.valor > 0 &&
        request.resource.data.status == 'pendente';
        
      // Atualização/Exclusão: Apenas administradores podem alterar o status (aprovar/recusar) ou deletar
      allow update, delete: if isAdmin();
    }

    // Coleção: shifts (Turnos/Rotas rápidas da central)
    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coleção: avisos (Canal de avisos admin → motoristas)
    match /avisos/{avisoId} {
      // Qualquer usuário autenticado pode ler avisos
      allow read: if isAuthenticated();
      // Apenas admins podem criar e excluir avisos
      allow create, delete: if isAdmin();
      // Motoristas podem apenas atualizar o campo 'lidos' (marcar como lido)
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lidos'])
      );
    }

    // Coleção: mensagens (Chat direto admin ↔ motorista)
    // Cada documento é uma conversa identificada pelo email do motorista
    match /mensagens/{conversaId} {
      allow read, write: if isAuthenticated();

      // Subcoleção de mensagens individuais da conversa
      match /msgs/{msgId} {
        // Leitura: participantes da conversa (motorista ou admin)
        allow read: if isAuthenticated();
        // Criação: qualquer usuário autenticado pode criar mensagens
        allow create: if isAuthenticated();
        // Atualização: apenas para marcar como lido
        allow update: if isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lido']);
        allow delete: if isAdmin();
      }
    }

    // Coleção: mensagens_meta (Metadados das conversas para listagem do admin)
    match /mensagens_meta/{metaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
