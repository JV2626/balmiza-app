{
  "expo": {
    "name": "balmiza-app",
    "slug": "balmiza-app",
    "version": "1.0.0",
    "sdkVersion": "56.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.balmiza-app"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC"
      ],
      "package": "com.jv2626.balmizaapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permissão para fotografar o hodômetro."
        }
      ],
      "expo-sharing",
      "expo-local-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "9a371ac6-7586-4c1c-8b60-aafef3456b58"
      }
    }
  }
}
